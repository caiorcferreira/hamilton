{
  "name": "hamilton",
  "version": "0.1.0",
  "type": "module",
  "private": true,
  "bin": {
    "hamilton": "dist/cli/main.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "bun --bun vitest run",
    "test:file": "bun --bun vitest run --reporter=verbose",
    "test:agent": "bun --bun vitest run 2>&1 | tail -8",
    "install-local": "bun run build && mkdir -p ~/.local/bin && ln -sf $(pwd)/dist/cli/main.js ~/.local/bin/hamilton && chmod +x dist/cli/main.js",
    "purge": "rm -f ~/.local/bin/hamilton; rm -rf ~/.hamilton/",
    "prepare": "effect-language-service patch"
  },
  "dependencies": {
    "@earendil-works/pi-agent-core": "0.78.1",
    "@earendil-works/pi-ai": "0.78.1",
    "@earendil-works/pi-coding-agent": "0.78.1",
    "@effect/cli": "0.75.2",
    "@effect/platform-bun": "0.90.0",
    "@effect/schema": "0.75.5",
    "@effect/workflow": "0.18.2",
    "@marcbachmann/cel-js": "^7.6.1",
    "@modelcontextprotocol/sdk": "1.12.0",
    "@narumitw/pi-lsp": "0.1.37",
    "@secretlint/core": "13.0.2",
    "@secretlint/secretlint-rule-preset-recommend": "13.0.2",
    "@tobilu/qmd": "2.5.3",
    "ajv": "^8.20.0",
    "effect": "3.21.4",
    "go-duration-js": "^0.1.3",
    "handlebars": "4.7.9",
    "nanoid": "3.3.12",
    "yaml": "2.4.5",
    "zod": "3.23.8",
    "zod-to-json-schema": "3.24.1"
  },
  "devDependencies": {
    "@effect/language-service": "^0.86.2",
    "@effect/vitest": "0.29.0",
    "@types/bun": "1.3.14",
    "@types/node": "22.16.0",
    "typescript": "5.9.3",
    "vitest": "4.1.8"
  },
  "patchedDependencies": {
    "@narumitw/pi-lsp@0.1.37": "patches/@narumitw%2Fpi-lsp@0.1.37.patch"
  }
}
